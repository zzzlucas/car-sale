# Mobile H5 local env example

# API uses same-origin /api in preprod deployment by default.
VITE_API_BASE_URL=/api
VITE_CAR_ANALYTICS_ENV=local

# Analytics collector origin.
# Real non-production value lives in:
# E:\web_work_-1\_workspace-base\ops\docs\resources-ai\car-preprod-env.md
VITE_CAR_ANALYTICS_ORIGIN=<analytics-collector-origin>

# Localhost stays silent unless this is true.
VITE_CAR_ANALYTICS_ENABLE_LOCAL=false
