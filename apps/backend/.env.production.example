# cloud2026 上的后端推荐通过进程环境变量或本文件同名副本提供生产配置
# 实际部署时请复制为 apps/backend/.env.production.local，并填写真实值

PORT=8120

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=car_platform
DB_PASSWORD=<生产库密码>
DB_NAME=car_platform

# 地图服务 provider：默认 tianditu；amap-official 为高德官方 Web 服务；amap/amap-proxy 为高德中转站
MAP_SERVICE_PROVIDER=amap-official

# 天地图 Web 服务配置；真实 Key 不提交 Git
TIANDITU_WEB_SERVICE_KEYS=<天地图Key，多个可用逗号分隔>
# TIANDITU_WEB_SERVICE_KEY=<单Key兼容入口>
TIANDITU_WEB_SERVICE_TIMEOUT_MS=2500
# TIANDITU_WEB_SERVICE_ACCESS=browser
TIANDITU_WEB_SERVICE_REFERER=<正式站点域名>

# 高德地图配置；MAP_SERVICE_PROVIDER=amap-official/amap-proxy 时使用；真实 Key 不提交 Git
AMAP_WEB_SERVICE_KEYS=<高德Key，多个可用逗号分隔>
# AMAP_WEB_SERVICE_KEY=<单Key兼容入口>
AMAP_WEB_SERVICE_TIMEOUT_MS=2500
# 以下中转站配置仅 MAP_SERVICE_PROVIDER=amap 或 amap-proxy 时使用
AMAP_WEB_SERVICE_PROXY_BASE_URL=<高德中转站地址，未使用可留空>
AMAP_WEB_SERVICE_PROXY_APPNAME=<高德中转站 appname，未使用可留空>
AMAP_WEB_SERVICE_PROXY_CALLBACK=jsonp_test
AMAP_WEB_SERVICE_PROXY_REFERER=<高德中转站 referer，未使用可留空>
AMAP_WEB_SERVICE_PROXY_X_REQUESTED_WITH=<高德中转站请求头，未使用可留空>

# COS 相关变量按需补充，不把真实密钥写入仓库
# COS_REGION=ap-guangzhou
# COS_BUCKET=car-platform
# COS_APP_ID=1250000000
# COS_SECRET_ID=<真实值>
# COS_SECRET_KEY=<真实值>
# COS_UPLOAD_PREFIX=car-platform-prod/
# COS_SIGN_EXPIRES=900
