# cloud2026 上的后端推荐通过进程环境变量或本文件同名副本提供生产配置
# 实际部署时请复制为 apps/backend/.env.production.local，并填写真实值

PORT=8120

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=car_platform
DB_PASSWORD=<生产库密码>
DB_NAME=car_platform

# COS 相关变量按需补充，不把真实密钥写入仓库
# COS_REGION=ap-guangzhou
# COS_BUCKET=car-platform
# COS_APP_ID=1250000000
# COS_SECRET_ID=<真实值>
# COS_SECRET_KEY=<真实值>
# COS_UPLOAD_PREFIX=car-platform-prod/
