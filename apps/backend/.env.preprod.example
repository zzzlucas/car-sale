# 预发布环境本地来源模板。
# 真实 apps/backend/.env.preprod 不提交 Git，可由 pnpm env:pull:preprod:backend 从远端拉取。

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=car_platform
DB_PASSWORD=change-me
DB_NAME=car_platform

MAP_SERVICE_PROVIDER=amap-official
TIANDITU_WEB_SERVICE_KEYS=change-me
TIANDITU_WEB_SERVICE_TIMEOUT_MS=2500
TIANDITU_WEB_SERVICE_ACCESS=browser
TIANDITU_WEB_SERVICE_REFERER=<预发布或正式站点域名>

AMAP_WEB_SERVICE_KEYS=change-me
AMAP_WEB_SERVICE_TIMEOUT_MS=2500
AMAP_WEB_SERVICE_PROXY_BASE_URL=<高德中转站地址，未使用可留空>
AMAP_WEB_SERVICE_PROXY_APPNAME=<高德中转站 appname，未使用可留空>
AMAP_WEB_SERVICE_PROXY_CALLBACK=jsonp_test
AMAP_WEB_SERVICE_PROXY_REFERER=<高德中转站 referer，未使用可留空>
AMAP_WEB_SERVICE_PROXY_X_REQUESTED_WITH=<高德中转站请求头，未使用可留空>

COS_REGION=ap-guangzhou
COS_BUCKET=car-platform
COS_APP_ID=1250000000
COS_SECRET_ID=change-me
COS_SECRET_KEY=change-me
COS_UPLOAD_PREFIX=car-platform-preprod/

AI_SUPPORT_PROVIDER=siliconflow
AI_SUPPORT_BASE_URL=https://api.siliconflow.cn/v1
AI_SUPPORT_API_KEYS=change-me
AI_SUPPORT_MODEL=deepseek-ai/DeepSeek-V3.2
AI_SUPPORT_TIMEOUT_MS=60000
AI_SUPPORT_LEVEL1_ALLOWLIST=deepseek-ai/DeepSeek-V3.2
AI_SUPPORT_FALLBACK_API_KEYS=
