# 本地开发数据库密码示例
DB_PASSWORD=<开发库密码>

# 如需覆盖默认直连 cloud2026 的配置，可额外打开以下项
# DB_HOST=124.222.31.238
# DB_PORT=3306
# DB_USERNAME=car_platform
# DB_NAME=car_platform

# 地图服务 provider：默认 tianditu；amap-official 为高德官方 Web 服务；amap/amap-proxy 为高德中转站
MAP_SERVICE_PROVIDER=tianditu

# 天地图 Web 服务 Key 池，支持逗号、空格或换行分隔
TIANDITU_WEB_SERVICE_KEYS=
# 单 Key 兼容入口；未配置池时会读取这一项
# TIANDITU_WEB_SERVICE_KEY=
# TIANDITU_WEB_SERVICE_TIMEOUT_MS=2500
# 天地图 Key 访问模式：browser 直连 REST + Referer；server 走天地图 ajaxproxy，适用于服务端 Key
# TIANDITU_WEB_SERVICE_ACCESS=browser
# 浏览器端天地图 Key 需要 Referer；本地默认 http://localhost:6173/
# TIANDITU_WEB_SERVICE_REFERER=http://localhost:6173/

# 高德地图 Key 池，支持逗号、空格或换行分隔；MAP_SERVICE_PROVIDER=amap-official/amap-proxy 时使用
AMAP_WEB_SERVICE_KEYS=
# 单 Key 兼容入口；未配置池时会读取这一项
# AMAP_WEB_SERVICE_KEY=
# AMAP_WEB_SERVICE_TIMEOUT_MS=2500

# 高德中转站链路配置；仅 MAP_SERVICE_PROVIDER=amap 或 amap-proxy 时使用；真实 Key 不提交 Git
AMAP_WEB_SERVICE_PROXY_BASE_URL=https://amap.bangban.cc/_AMapService
AMAP_WEB_SERVICE_PROXY_APPNAME=https%3A%2F%2Famap.bangban.cc%2Fdt.html
AMAP_WEB_SERVICE_PROXY_CALLBACK=jsonp_test
AMAP_WEB_SERVICE_PROXY_REFERER=https://amap.bangban.cc/dt.html
AMAP_WEB_SERVICE_PROXY_X_REQUESTED_WITH=com.bangban.cc
