# 本地开发数据库密码示例
DB_PASSWORD=<开发库密码>

# 如需覆盖默认直连 cloud2026 的配置，可额外打开以下项
# DB_HOST=124.222.31.238
# DB_PORT=3306
# DB_USERNAME=car_platform
# DB_NAME=car_platform

# 高德 Web 服务 Key 池，支持逗号、空格或换行分隔
AMAP_WEB_SERVICE_KEYS=
# 单 Key 兼容入口；未配置池时会读取这一项
# AMAP_WEB_SERVICE_KEY=
# AMAP_WEB_SERVICE_TIMEOUT_MS=2500
# 若买到的是通过代理链路可用的 Key，可额外配置：
# AMAP_WEB_SERVICE_PROXY_BASE_URL=https://amap.bangban.cc/_AMapService
# AMAP_WEB_SERVICE_PROXY_APPNAME=https%3A%2F%2Famap.bangban.cc%2Fdt.html
